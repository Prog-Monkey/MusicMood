# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Logs and databases
*.log
*.sqlite3

# Environment variables
.env
.env.local

# VS Code settings (keep settings.json, tasks.json, launch.json if needed)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Pytest cache
.pytest_cache/

# MyPy cache
.mypy_cache/

# Jupyter Notebook checkpoints
.ipynb_checkpoints

# OS-generated files
.DS_Store
Thumbs.db   
